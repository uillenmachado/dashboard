# ========================================
# Dashboard Analítico - Configuração
# ========================================

# Porta do servidor (padrão: 3000)
PORT=3000

# Ambiente (development | production)
NODE_ENV=development

# Nível de log (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info

# Origens CORS permitidas (separadas por vírgula)
# Em produção é OBRIGATÓRIO definir.
# CORS_ORIGINS=http://localhost:3000,https://dashboard.exemplo.com

# ========================================
# Autenticação básica do dashboard (opcional)
# Se ambos definidos, exige Basic Auth em todas as rotas (exceto /health)
# ========================================
DASHBOARD_USER=
DASHBOARD_PASS=

# ========================================
# Portal NFS-e MetropolisWEB (Lauro de Freitas)
# ========================================
NFSE_LOGIN=
NFSE_SENHA=

# ========================================
# Painel Fornecedor Finnet (Cimed)
# ========================================
FINNET_EMAIL=
FINNET_SENHA=

# ========================================
# Manutenção
# ========================================
# Dias de retenção dos arquivos em data/debug/ (default: 14)
DEBUG_RETENTION_DAYS=14

# Cron de backup do banco (default: todo dia às 02:00)
BACKUP_CRON=0 2 * * *

# Quantos backups manter (default: 7)
BACKUP_KEEP=7

# ========================================
# Banco do Brasil API (futuro)
# ========================================
BB_CLIENT_ID=
BB_CLIENT_SECRET=
BB_APP_KEY=
